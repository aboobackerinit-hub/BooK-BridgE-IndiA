{
  "version": 2,
  "buildCommand": "cd frontend && yarn install && CI=false yarn build",
  "outputDirectory": "frontend/build",
  "framework": null,
  "build": {
    "env": {
      "VERCEL_PYTHON_PACKAGE_MANAGER": "pip",
      "PIP_DISABLE_PIP_VERSION_CHECK": "1"
    }
  },
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    { "source": "/api", "destination": "/api/index.py" },
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
