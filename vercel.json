{
  "version": 2,
  "buildCommand": "cd frontend && npm install --legacy-peer-deps && CI=false npm run build",
  "outputDirectory": "frontend/build",
  "build": {
    "env": {
      "PYTHON_VERSION": "3.12",
      "PYO3_USE_ABI3_FORWARD_COMPATIBILITY": "1",
      "SKIP_CYTHON": "1",
      "PURE_PYTHON": "1"
    }
  },
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
